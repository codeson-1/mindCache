  "metrics": {
    "primary": "Top-5 命中率 = 相关 item 出现在前 5 结果中的 query 数 / 总 query 数",
    "secondary": ["MRR (Mean Reciprocal Rank)", "NDCG@5"]
  },
  "ablationPlan": {
    "description": "消融实验：分别关闭一路召回，验证每一路的独立贡献",
    "experiments": [
      { "name": "仅 pgvector 语义检索", "config": "alpha=1.0, beta=0.0, gamma=0.0", "expectedTop5Rate": "~72%" },
      { "name": "仅 Lucene BM25 关键词", "config": "alpha=0.0, beta=1.0, gamma=0.0", "expectedTop5Rate": "~68%" },
      { "name": "仅时间衰减", "config": "alpha=0.0, beta=0.0, gamma=1.0", "expectedTop5Rate": "按时间倒序" },
      { "name": "双路融合（无时间衰减）", "config": "alpha=0.6, beta=0.4, gamma=0.0", "expectedTop5Rate": "~82%" },
      { "name": "三路融合（推荐基线）", "config": "alpha=0.5, beta=0.3, gamma=0.2", "expectedTop5Rate": "~85%" }
    ]
  }
