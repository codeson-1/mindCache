{
  "description": "第5周检索评测数据集 — 20条预设自然语言query，支撑消融实验和α/β/γ调参。",
  "version": "1.0",
  "createdAt": "2025-06-12",
  "queryCategories": {
    "keyword_exact": "关键词精确型 — 含具体术语，期望BM25贡献高",
    "semantic_fuzzy": "语义模糊型 — 无精确关键词，期望向量语义贡献高",
    "time_sensitive": "时间敏感型 — 含时间限定词，期望时间衰减起正向作用"
  },
  "queries": [
